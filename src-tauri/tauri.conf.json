{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentic Legibility Chat",
  "version": "0.1.4",
  "identifier": "digital.considerate.legibility-chat",
  "build": {
    "beforeDevCommand": "cd ../ui && pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../ui && pnpm build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agentic Legibility Chat",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/legibility-chat-mcp"],
    "resources": [
      "resources/defaults/states",
      "resources/defaults/cards",
      "resources/defaults/tools/state"
    ]
  }
}
